# sync-docs env vars. Append to .env or .env.local. All are optional - both
# syncs skip cleanly if their inputs are missing.

# --- API sync (pick ONE) ---------------------------------------------------
# 1. Full URL to the OpenAPI JSON. Wins if set.
# API_DOCS_URL=http://10.0.0.1:8000/openapi.json
#
# 2. Base URL; "<base>/openapi.json" is fetched.
# API_BASE_URL=http://10.0.0.1:8000
#
# 3. Falls back to REACT_APP_BASE_URL if you already have it for the app.
# REACT_APP_BASE_URL=http://10.0.0.1:8000

# --- Tuning ----------------------------------------------------------------
# Background self-throttle window. Default 6 hours.
# DOCS_SYNC_INTERVAL_HOURS=6
